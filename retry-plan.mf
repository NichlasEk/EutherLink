  "Reloaded ssh and verified password-only login is denied with Permission denied (publickey)."
]
eutherbooks = [
  "Added an eutherlink TTS backend in /home/nichlas/EutherBooks/eutherbooks/tts.py on the server.",
  "Backend posts jobs to EutherLink, polls status, downloads WAV audio, and writes it into the existing EutherBooks audio path.",
